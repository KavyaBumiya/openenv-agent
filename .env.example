# ============================================================
# Required — set these before running inference.py
# ============================================================

# LLM endpoint (OpenAI-compatible)
# HuggingFace router:  https://router.huggingface.co/v1
# Local Ollama:        http://localhost:11434/v1
API_BASE_URL=https://router.huggingface.co/v1

# Model name (must be valid for the endpoint above)
# HF router examples: meta-llama/Llama-3.1-8B-Instruct
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# API key / token
# Required token for OpenAI-compatible calls.
HF_TOKEN=your_openai_compatible_token_here

# Optional local Docker image for OpenEnv from_docker_image()-style workflows.
# Keep empty when running HTTP mode against ENV_BASE_URL.
LOCAL_IMAGE_NAME=

# ============================================================
# Optional — base URL of deployed environment (for HTTP mode)
# ============================================================
# ENV_BASE_URL=https://your-username-customer-support-env.hf.space
