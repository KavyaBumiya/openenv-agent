# ============================================================================
# MANDATORY: OpenAI-Compatible LLM Configuration
# ============================================================================
# These variables are used by inference.py for baseline evaluation

# API Endpoint - supports any OpenAI-compatible API
# Examples:
#   - Hugging Face Inference API: https://router.huggingface.co/v1
#   - Groq API: https://api.groq.com/openai/v1
#   - Ollama local: http://localhost:11434/v1
API_BASE_URL=https://router.huggingface.co/v1

# Model Name - must be compatible with the API endpoint
# Examples:
#   - Hugging Face router: meta-llama/Llama-2-7b-chat-hf
#   - Groq: llama-3.3-70b-versatile
#   - Local Ollama: llama2
MODEL_NAME=meta-llama/Llama-2-7b-chat-hf

# API Key / Token - authentication for the LLM provider
# Get your token from:
#   - Hugging Face: https://huggingface.co/settings/tokens (make sure to use "Write" or "Admin" permission)
#   - Groq: https://console.groq.com/keys
#   - OpenAI: https://platform.openai.com/api-keys
HF_TOKEN=hf_your_token_here

# ============================================================================
# OPTIONAL: Groq-Specific Configuration (for run_official_benchmark.py)
# ============================================================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Model selection (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# OPTIONAL: Development & Testing Configuration
# ============================================================================

# Temperature settings (for development/testing)
TEMPERATURE_CLASSIFY=0.1
TEMPERATURE_ROUTE=0.5
TEMPERATURE_RESOLVE=0.7

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# Benchmark settings
BENCHMARK_NUM_EPISODES=30
BENCHMARK_TEMPERATURE_MODE=official
