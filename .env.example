# Groq LLM API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Model selection (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Temperature settings (for development/testing)
TEMPERATURE_CLASSIFY=0.1
TEMPERATURE_ROUTE=0.5
TEMPERATURE_RESOLVE=0.7

# Optional: Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# Optional: Benchmark settings
BENCHMARK_NUM_EPISODES=30
BENCHMARK_TEMPERATURE_MODE=official
